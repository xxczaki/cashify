{
	"compilerOptions": {
		"outDir": "dist",
		"target": "es2024",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["es2024"],
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src/**/*"]
}
